VITE_API_BASE_URL=https://tacticl-core-qa-bflhiwsnmq-ue.a.run.app

# ── Voice command center (/command) ─────────────────────────────────────────
# Set VITE_VOICE_WS_URL to enable the LIVE voice backend (tacticl-core voice
# WebSocket: Deepgram STT + ElevenLabs TTS run server-side). When unset, the
# command center falls back to the in-browser MOCK so the demo still works.
#
# The client first POSTs the token URL (with the stored auth bearer) to get a
# short-lived session token, then opens the WebSocket as {WS_URL}?token=...
VITE_VOICE_WS_URL=wss://api.tacticl.ai/v1/voice/stream
# Optional. Absolute URL or a path resolved against VITE_API_BASE_URL.
# Defaults to {VITE_API_BASE_URL}/v1/voice/token when omitted.
VITE_VOICE_TOKEN_URL=/v1/voice/token
